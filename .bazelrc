build --java_language_version=17
build --tool_java_language_version=17
build --java_runtime_version=remotejdk_17
build --tool_java_runtime_version=remotejdk_17

# Unset ANDROID_HOME to prevent rules_android from searching for the Android SDK.
# rules_android is a transitive dependency, and on GitHub runners the Android SDK
# directory is often deleted while the ANDROID_HOME environment variable remains set.
common --action_env=ANDROID_HOME=""

test --test_output=errors

common --@score_baselibs//score/json:base_library=nlohmann
common --@score_communication//score/mw/com/flags:tracing_library=@score_baselibs//score/analysis/tracing/generic_trace_library/stub_implementation
common --//score/config_management/config_daemon/code:score_variant=True
common --registry=https://raw.githubusercontent.com/eclipse-score/bazel_registry/main/
common --registry=https://bcr.bazel.build

# Host GCC toolchain — used by CI (tests.yml, static-analysis.yml)
# score_bazel_cpp_toolchains gcc module extension generates @score_gcc_x86_64_toolchain
build:host_gcc --extra_toolchains=@score_gcc_x86_64_toolchain//:x86_64-linux-gcc_12.2.0
build:host_gcc --host_platform=@score_bazel_platforms//:x86_64-linux
# Set target platform to gcc_12.2.0-posix so GCC toolchain's target_compatible_with
# constraint is satisfied and GCC is actually selected (LLVM is the default otherwise).
build:host_gcc --platforms=@score_bazel_platforms//:x86_64-linux-gcc_12.2.0-posix

# score_baselibs deprecated StringLiteral but still uses it in many headers
# (string_comparison_adaptor.h, text_format.h, etc.). These headers are included
# transitively by our own code, so the -Werror,-Wdeprecated-declarations error
# fires in ALL translation units that pull in score/json or score/mw/log.
# score_baselibs' own CI uses GCC (dev_dependency toolchain) which doesn't
# treat deprecated-declarations as errors. Suppress globally until upstream
# removes the deprecated usages from their public headers.
build --copt=-Wno-deprecated-declarations
# score_logging commit 3ad4fab (May 15) introduced an unused 'result' variable in
# data_router_message_client_impl.cpp (PThreadBlockSigTerm return value discarded).
# No upstream fix exists yet. Suppress -Wunused-variable for all external/ source
# files (does NOT affect our own code in score/ or tests/).
build --per_file_copt=external/.*@-Wno-unused-variable

coverage --features=coverage
coverage --combined_report=lcov
coverage --cache_test_results=no
coverage --copt=-fprofile-update=atomic
coverage --linkopt=-fprofile-update=atomic
